# Copy to .env in project root for Docker Compose
JWT_SECRET=dev-jwt-secret-change-in-production
ADMIN_EMAIL=admin@leapai.ai
ADMIN_PASSWORD=admin123

# Public site URL (required for GEO/SEO — baked into llms.txt, robots.txt, sitemap)
NEXT_PUBLIC_SITE_URL=https://leapai-webhook.bab.solutions/leap-ai
NEXT_PUBLIC_BASE_PATH=/leap-ai
CORS_ORIGIN=https://leapai-webhook.bab.solutions,https://leapai-webhook.bab.solutions/leap-ai

# Frontend (local dev)
NEXT_PUBLIC_API_URL=http://localhost:4000

# Backend (local dev) — see backend/.env.example
MONGODB_URI=mongodb://leap:leapsecret@localhost:27017/leapai?authSource=admin
REDIS_URL=redis://localhost:6379
