# Production environment — copy to server and adjust secrets.
# Frontend: frontend/.env.production.local (or export before `npm run build`)
# Backend:  backend/.env

# ── Public site (required for SEO, GEO, sitemap, links) ──
NEXT_PUBLIC_SITE_URL=https://leapai-webhook.bab.solutions/leap-ai
NEXT_PUBLIC_BASE_PATH=/leap-ai
NEXT_PUBLIC_API_URL=/backend

# ── Frontend server (Next.js SSR / rewrites) ──
API_URL=http://localhost:4000
INTERNAL_API_URL=http://localhost:4000
NODE_ENV=production

# ── Backend API ──
PORT=4000
MONGODB_URI=mongodb://leap:CHANGE_ME@localhost:27017/leapai?authSource=admin
REDIS_URL=redis://localhost:6379
JWT_SECRET=CHANGE_ME-long-random-secret
CORS_ORIGIN=https://leapai-webhook.bab.solutions,https://leapai-webhook.bab.solutions/leap-ai
ADMIN_EMAIL=admin@leapai.ai
ADMIN_PASSWORD=CHANGE_ME
ENFORCE_PROD_SECRETS=true

# ── Deploy steps ──
# 1. Copy this file values into frontend/.env.production.local and backend/.env
# 2. cd frontend && npm run build
# 3. pm2 start ecosystem.config.cjs --env production
# 4. Verify: https://leapai-webhook.bab.solutions/leap-ai/llms.txt
