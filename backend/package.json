{
  "name": "leap-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:local": "cross-env USE_MEMORY_DB=true tsx watch src/index.ts",
    "seed:local": "cross-env USE_MEMORY_DB=true tsx src/seed.ts",
    "build": "tsc && node -e \"require('fs').cpSync('src/data','dist/data',{recursive:true})\"",
    "start": "node dist/index.js",
    "seed": "tsx src/seed.ts",
    "sync": "tsx src/sync-content.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.16.0",
    "multer": "^2.2.0",
    "redis": "^5.12.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.0.3",
    "cross-env": "^10.1.0",
    "mongodb-memory-server": "^11.2.0",
    "tsx": "^4.20.3",
    "typescript": "^5.7.3"
  }
}
